{
  "name": "obsidian-investment-research",
  "version": "0.1.0",
  "description": "Professional investment research IDE plugin for Obsidian - focused on fundamental analysis and knowledge management",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "investment",
    "research",
    "stock",
    "financial"
  ],
  "author": "SiberiaW",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.8",
    "esbuild-sass-plugin": "^2.16.0",
    "eslint": "^8.54.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "chrono-node": "^2.7.0",
    "obsidian-daily-notes-interface": "^0.9.4"
  }
}
